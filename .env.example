# Шаблон переменных окружения. Скопируйте в .env (dev) или .env.prod (прод)
# и заполните. РЕАЛЬНЫЕ значения НЕ коммитить (.env / .env.* в .gitignore).
# ВАЖНО: не пишите комментарии в той же строке, что и значение — docker env_file
# не обрезает их и они попадут в значение. Комментарии — только отдельной строкой.

# ─── Основное ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vkusno:CHANGE_ME@db:5432/vkusno
# SECRET_KEY — подпись JWT, обязательно длинная случайная строка
SECRET_KEY=CHANGE_ME
# SITE_URL — прод: https://ваш-домен ; dev: http://v2.вашдомен:8000
SITE_URL=https://vkusnotomsk.ru
# COOKIE_SECURE — dev: false (HTTP), prod: true (HTTPS)
COOKIE_SECURE=true

# ─── Postgres (docker-compose.prod.yml) ───────────────────────────────────────
POSTGRES_DB=vkusno
POSTGRES_USER=vkusno
POSTGRES_PASSWORD=CHANGE_ME

# ─── Админка ──────────────────────────────────────────────────────────────────
# ADMIN_URL_SECRET — вход: /admin/login/<этот_секрет>
ADMIN_URL_SECRET=CHANGE_ME
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=CHANGE_ME

# ─── Оплата (ЮKassa) ──────────────────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=

# ─── Подтверждение входа ──────────────────────────────────────────────────────
# SMS через Plusofon (основной канал). Client всегда 10553.
PLUSOFON_CLIENT_ID=10553
PLUSOFON_TOKEN=
PLUSOFON_NUMBER_ID=
# Telegram Gateway (код по номеру)
TG_GATEWAY_TOKEN=
# SMS.RU (резервный шлюз)
SMSRU_API_ID=
# i-dgtl (опционально)
IDGTL_API_KEY=
IDGTL_GATEWAY_ID=
# Яндекс SmartCaptcha (антибот на входе)
SMARTCAPTCHA_SITEKEY=
SMARTCAPTCHA_SECRET=

# ─── Адреса/геокодинг ─────────────────────────────────────────────────────────
DADATA_TOKEN=
DADATA_SECRET=

# ─── Уведомления ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
TG_BOT_TOKEN=
TG_BOT_USERNAME=
MAX_API_KEY=
OPERATOR_TG_CHAT_ID=
